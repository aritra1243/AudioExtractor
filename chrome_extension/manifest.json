{
  "manifest_version": 3,
  "name": "AudioExtractor - Local MP4 to MP3",
  "version": "1.6.0",
  "description": "Convert MP4 videos to MP3 audio locally in your browser using WebAssembly. No uploads required.",
  "permissions": [
    "offscreen"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "ffmpeg-core.js",
        "ffmpeg-core.wasm"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
